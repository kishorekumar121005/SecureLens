# ================================================================
# SecureLens - .gitignore
# ================================================================

# ── Java / Spring Boot ─────────────────────────────────────────
backend-java/target/
*.class
*.jar
*.war
*.ear
*.nar
*.zip
*.tar.gz
*.rar

# ── Maven ──────────────────────────────────────────────────────
backend-java/.mvn/wrapper/maven-wrapper.jar
backend-java/mvnw
backend-java/mvnw.cmd

# ── Environment & Secrets (NEVER commit these) ─────────────────
.env
*.env
.env.local
.env.production
backend-java/.env
backend-java/src/main/resources/application.yml
backend-java/src/main/resources/application-prod.yml

# ── React Dashboard ────────────────────────────────────────────
web-dashboard/node_modules/
web-dashboard/dist/
web-dashboard/.vite/
web-dashboard/.env
web-dashboard/.env.local
web-dashboard/.env.production

# ── Node modules anywhere ──────────────────────────────────────
node_modules/
**/node_modules/

# ── VS Code ────────────────────────────────────────────────────
.vscode/
*.code-workspace
.idea/

# ── Windows ────────────────────────────────────────────────────
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
ehthumbs.db

# ── Mac ────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Logs ───────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Build outputs ──────────────────────────────────────────────
dist/
build/
out/